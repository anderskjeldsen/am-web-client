        // Bounce a continuation resume back onto the main-thread queue.
        // Called from the IO worker once the HTTP exchange is done — the
        // post-suspend body then runs inside whichever
        // handleMainTasks() drain picks the resume task up.
        //
        // Hoisted to a static helper so the IO-worker lambda doesn't
        // have to inline yet another lambda (inline `new`-as-arg lambdas
        // have NPE'd the renderer historically).
        private fun resumeOnMain(cont: Continuation) {
            var resumeTask: () => Bool = () => {
                cont.resume()
                return true
            }
            TaskScheduler.schedule(TaskThreadType.Main, resumeTask)
        }
    }

    // Plain mutable holder — the IO worker writes one of `response`
    // (success) or `errorMessage` (failure) before resuming the
    // continuation. Internal to AsyncWebClient; callers see only
    // HttpResponse or a thrown Exception.
    class AsyncWebResult {
        import Am.Lang

        var response: HttpResponse
        var errorMessage: String
    }
}
